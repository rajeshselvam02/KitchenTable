# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://kitchentable:<YOUR_DB_PASSWORD>@localhost:5432/kitchentable_dev

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<GENERATE_A_STRONG_RANDOM_SECRET>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# ── Docker Compose (copy these to a root .env file) ───────────────────────────
# POSTGRES_USER=kitchentable
# POSTGRES_PASSWORD=<YOUR_DB_PASSWORD>
# POSTGRES_DB=kitchentable_dev
# NEXTAUTH_SECRET=<GENERATE_A_STRONG_RANDOM_SECRET>
# NEXTAUTH_URL=http://localhost:3000
